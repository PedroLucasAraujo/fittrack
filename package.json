{
  "name": "@fittrack/root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint packages/",
    "lint:fix": "eslint packages/ --fix",
    "format": "prettier --write \"packages/**/*.ts\"",
    "format:check": "prettier --check \"packages/**/*.ts\"",
    "typecheck": "npm run typecheck:core && npm run typecheck:identity && npm run typecheck:billing && npm run typecheck:scheduling && npm run typecheck:achievements && npm run typecheck:session-feedback && npm run typecheck:assessments && npm run typecheck:catalog && npm run typecheck:challenges && npm run typecheck:deliverables && npm run typecheck:execution && npm run typecheck:gamification && npm run typecheck:goals && npm run typecheck:ledger && npm run typecheck:platform && npm run typecheck:reviews && npm run typecheck:metrics && npm run typecheck:self-log && npm run typecheck:risk",
    "typecheck:core": "cd packages/core && npx tsc --noEmit",
    "typecheck:identity": "cd packages/identity && npx tsc --noEmit",
    "typecheck:billing": "cd packages/billing && npx tsc --noEmit",
    "typecheck:scheduling": "cd packages/scheduling && npx tsc --noEmit",
    "typecheck:achievements": "cd packages/achievements && npx tsc --noEmit",
    "typecheck:session-feedback": "cd packages/session-feedback && npx tsc --noEmit",
    "typecheck:assessments": "cd packages/assessments && npx tsc --noEmit",
    "typecheck:catalog": "cd packages/catalog && npx tsc --noEmit",
    "typecheck:challenges": "cd packages/challenges && npx tsc --noEmit",
    "typecheck:deliverables": "cd packages/deliverables && npx tsc --noEmit",
    "typecheck:execution": "cd packages/execution && npx tsc --noEmit",
    "typecheck:gamification": "cd packages/gamification && npx tsc --noEmit",
    "typecheck:goals": "cd packages/goals && npx tsc --noEmit",
    "typecheck:ledger": "cd packages/ledger && npx tsc --noEmit",
    "typecheck:platform": "cd packages/platform && npx tsc --noEmit",
    "typecheck:reviews": "cd packages/reviews && npx tsc --noEmit",
    "typecheck:metrics": "cd packages/metrics && npx tsc --noEmit",
    "typecheck:self-log": "cd packages/self-log && npx tsc --noEmit",
    "typecheck:risk": "cd packages/risk && npx tsc --noEmit",
    "test": "npm run test:core && npm run test:identity && npm run test:billing && npm run test:scheduling && npm run test:achievements && npm run test:session-feedback && npm run test:assessments && npm run test:catalog && npm run test:challenges && npm run test:deliverables && npm run test:execution && npm run test:gamification && npm run test:goals && npm run test:ledger && npm run test:platform && npm run test:reviews && npm run test:metrics && npm run test:self-log && npm run test:risk",
    "test:core": "cd packages/core && npx vitest run --coverage",
    "test:identity": "cd packages/identity && npx vitest run --coverage",
    "test:billing": "cd packages/billing && npx vitest run --coverage",
    "test:scheduling": "cd packages/scheduling && npx vitest run --coverage",
    "test:achievements": "cd packages/achievements && npx vitest run --coverage",
    "test:session-feedback": "cd packages/session-feedback && npx vitest run --coverage",
    "test:assessments": "cd packages/assessments && npx vitest run --coverage",
    "test:catalog": "cd packages/catalog && npx vitest run --coverage",
    "test:challenges": "cd packages/challenges && npx vitest run --coverage",
    "test:deliverables": "cd packages/deliverables && npx vitest run --coverage",
    "test:execution": "cd packages/execution && npx vitest run --coverage",
    "test:gamification": "cd packages/gamification && npx vitest run --coverage",
    "test:goals": "cd packages/goals && npx vitest run --coverage",
    "test:ledger": "cd packages/ledger && npx vitest run --coverage",
    "test:platform": "cd packages/platform && npx vitest run --coverage",
    "test:reviews": "cd packages/reviews && npx vitest run --coverage",
    "test:metrics": "cd packages/metrics && npx vitest run --coverage",
    "test:self-log": "cd packages/self-log && npx vitest run --coverage",
    "test:risk": "cd packages/risk && npx vitest run --coverage",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "8.57.0",
    "@typescript-eslint/parser": "8.57.0",
    "eslint": "10.0.3",
    "husky": "9.1.7",
    "lint-staged": "16.3.3",
    "prettier": "3.8.1",
    "typescript-eslint": "8.57.0"
  },
  "lint-staged": {
    "packages/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "engines": {
    "node": ">=22"
  }
}
